  };

    // 精確匹配大學名稱
    if (features[schoolName]) {
      return features[schoolName];
    }

    // 模糊匹配 - 改進的匹配算法
    const normalizedSchoolName = schoolName.toLowerCase().trim();

    // 然後嘗試模糊匹配
    for (const [key, value] of Object.entries(features)) {
      const normalizedKey = key.toLowerCase().trim();

      // 雙向包含匹配
      if (normalizedKey.includes(normalizedSchoolName) || 
          normalizedSchoolName.includes(normalizedKey)) {
        return value;
      }

      // 關鍵詞匹配 - 移除常見的詞綴和詞綴來進行匹配
      const cleanSchoolName = normalizedSchoolName
        .replace(/the\s+/g, "")
        .replace(/university\s+of/g, "")
        .replace(/university/g, "")
        .replace(/\s+/g, " ")
        .trim();

      const cleanKey = normalizedKey
        .replace(/the\s+/g, "")
        .replace(/university\s+of/g, "")
        .replace(/university/g, "")
        .replace(/\s+/g, " ")
        .trim();

      if (cleanSchoolName === cleanKey || 
          cleanSchoolName.includes(cleanKey) || 
          cleanKey.includes(cleanSchoolName)) {
        return value;
      }
    }

    // 如果沒有匹配到任何大學，返回 null 不顯示特色信息
    return null;
  };


  const featureData = getSchoolFeatures(schoolName);

  // 如果沒有匹配到大學特色信息，不顯示組件
  if (!featureData) {
    return null;
  }


  return (
    <div className="school-features">
      <div 
        className="features-header" 
        onClick={() => setShowFeatures(!showFeatures)}
      >
        <div className="mini" style={{ 
          color: "var(--muted)", 
          fontWeight: "bold", 
          display: "flex", 
          alignItems: "center", 
          gap: "8px",
          flex: 1,
          minWidth: 0
        }}>
          🎓 大學特色
          <span 
            className="school-name-badge" 
            title={schoolName}
          >
            {schoolName.length > 15 ? schoolName.substring(0, 15) + "..." : schoolName}
          </span>
        </div>
        <span 
          className="arrow-icon" 
          style={{ 
            transform: showFeatures ? "rotate(180deg)" : "rotate(0deg)"
          }}
        >
          ▼
        </span>
      </div>

      {showFeatures && (
        <div className="features-grid">
          {featureData.school_features && (
            <div 
              className="feature-item" 
              style={{ 
                backgroundColor: "var(--soft)", 
                borderLeft: "4px solid var(--brand)"
              }}
            >
              <div className="feature-title">
                🎓 學校特色
              </div>
              <div className="feature-content">
                {featureData.school_features}
              </div>
            </div>
          )}

          {featureData.city_features && (
            <div 
              className="feature-item" 
              style={{ 
                backgroundColor: "var(--soft)", 
                borderLeft: "4px solid var(--accent)"
              }}
            >
              <div className="feature-title">
                🏙️ 城市特色
              </div>
              <div className="feature-content">
                {featureData.city_features}
              </div>
            </div>
          )}

          <div className="features-row">
            {featureData.climate && (
              <div 
                className="feature-item" 
                style={{ 
                  backgroundColor: "#f0f9ff", 
                  borderLeft: "4px solid #0ea5e9"
                }}
              >
                <div className="feature-title">
                  🌤️ 氣候
                </div>
                <div className="feature-content" style={{ lineHeight: "1.5" }}>
                  {featureData.climate}
                </div>
              </div>
            )}

            {featureData.food_culture && (
              <div 
                className="feature-item" 
                style={{ 
                  backgroundColor: "#fff7ed", 
                  borderLeft: "4px solid #f97316"
                }}
              >
                <div className="feature-title">
                  🍜 美食文化
                </div>
                <div className="feature-content" style={{ lineHeight: "1.5" }}>
                  {featureData.food_culture}
                </div>
              </div>
            )}
          </div>

          {featureData.transportation && (
            <div 
              className="feature-item" 
              style={{ 
                backgroundColor: "#f3e8ff", 
                borderLeft: "4px solid #a855f7"
              }}
            >
              <div className="feature-title">
                🚌 交通
              </div>
              <div className="feature-content" style={{ lineHeight: "1.5" }}>
                {featureData.transportation}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );

};

export default SchoolFeaturesDisplay;
